---
# Monitoring secrets for relay-devnet-test — DO NOT COMMIT the filled file.
#
# On the deployment host:
#   cp vars/relay-devnet-test/monitoring_secrets.yaml.example vars/monitoring_secrets.yaml
# then fill in the values. vars/monitoring_secrets.yaml is gitignored.
#
# Same backends as relay-devnet-01 (influxdb.sov-obs.xyz / sov-obs Loki+Tempo);
# metrics are separated by deployment_name=relay-devnet-test from params.yaml.

# Telegraf -> InfluxDB (devnet env var: RELAY_DEVNET_INFLUX_TOKEN)
influxdb_token: "<influx-token>"

# Grafana Alloy -> Loki/Tempo (devnet env var: RELAY_DEVNET_ALLOY_PASSWORD)
grafana_loki_token: "<alloy-password>"
grafana_tempo_token: "<alloy-password>"
