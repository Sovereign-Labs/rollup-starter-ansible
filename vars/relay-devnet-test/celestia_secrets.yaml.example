---
# Celestia MOCHA secrets for relay-devnet-test — DO NOT COMMIT the filled file.
#
# On the deployment host:
#   cp vars/relay-devnet-test/celestia_secrets.yaml.example vars/celestia_secrets.yaml
# then fill in the values below. vars/celestia_secrets.yaml is gitignored.
#
# All endpoints/keys must be for MOCHA, not mainnet. For reference, the
# mainnet devnet (relay-devnet-01) uses a celestia-node RPC on :26658 and a
# QuickNode consensus gRPC on :9090 — you need the mocha equivalents.

# celestia-node (light/bridge) JSON-RPC endpoint, mocha
celestia_rpc_url: "http://<mocha-celestia-node-host>:26658"

# Consensus node gRPC endpoint, mocha (e.g. a QuickNode mocha endpoint)
celestia_grpc_url: "https://<mocha-grpc-host>:9090"

# Auth token for the gRPC endpoint (empty string if none required)
celestia_grpc_auth_token: "<token-or-empty>"

# Celestia account private key, 64-char hex. MUST hold mocha TIA for blob fees.
# The devnet key (address celestia1sd4zxakkhwd43mcj9s0gqxqsd8slz4uejllmd5,
# env RELAY_DEVNET_CELESTIA_PRIVATE_KEY_LMD5) can be reused IF it is funded on
# mocha; otherwise create and fund a fresh one (https://mocha.celenium.io to
# verify balance, faucet: https://faucet.celestia-mocha.com/).
signer_private_key: "<64-hex-private-key>"

# Address corresponding to signer_private_key (celestia1...)
da_rollup_address: "celestia1..."
