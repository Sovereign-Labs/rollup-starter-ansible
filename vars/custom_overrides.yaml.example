---
# Custom Variable Overrides
# Copy this file to custom_overrides.yaml and uncomment/modify variables you want to override
# This file is loaded automatically if it exists and has higher precedence than role defaults

# ============================================
# Common Infrastructure Variables
# ============================================

# Storage paths
# rollup_storage_dir: "/mnt/rollup"
# rollup_log_dir: "/mnt/logs"
# Only for mock_da
# da_store: "/mnt/da"

# System limits
# max_open_files: 1000000

# Monitoring endpoints (InfluxDB, Loki, Tempo)
# influxdb_url: "https://influx-prod-03-prod-us-central-0.grafana.net"
# influxdb_bucket: "sovereign"
# loki_url: "https://logs-prod-017.grafana.net/loki/api/v1/push"
# tempo_url: "https://tempo-prod-10-prod-us-central-0.grafana.net:443"

# Secondary InfluxDB outputs (tokens go in monitoring_secrets.yaml)
# influxdb_secondary_outputs:
#   - name: "grafana-cloud"
#     url: "https://influx-prod.grafana.net"
#     org: "my-org"
#     bucket: "prod-metrics"

# ============================================
# Rollup Configuration
# ============================================

# GitHub repository details
# Full git URL - use HTTPS for public repos, git@github.com:org/repo.git for private repos with SSH keys
# rollup_repo: "https://github.com/Sovereign-Labs/rollup-starter.git"
# rollup_repo_dir: "rollup-starter"

# IMPORTANT: Git commit hash to deploy
# rollup_commit_hash: "main"

# Binary name
# rollup_bin: "rollup"

# zkVM implementation: "mock_zkvm", "risc0", or "sp1"
# zkvm_role: "mock_zkvm"

# Genesis operating mode: "operator", "zk", or "optimistic"
# rollup_genesis_operating_mode: "operator"

# Genesis code commitments. Required to be non-zero when using zk/optimistic
# mode with a real zkVM ("risc0" or "sp1").
# rollup_genesis_inner_code_commitment: [0, 0, 0, 0, 0, 0, 0, 0]
# rollup_genesis_outer_code_commitment: [0, 0, 0, 0, 0, 0, 0, 0]

# Build mode: true for debug, false for release
# debug: true

# Ports
# rollup_http_port: 12346

# Wipe data on deployment (DANGEROUS!)
# wipe: false

# ============================================
# Rate Limiter (Preferred Sequencer Only)
# ============================================

# rollup_rate_limiter_enabled: true
# rollup_rate_limiter_max_concurrent_users: 100000
# rollup_rate_limiter_max_requests_per_second: 10000
# rollup_rate_limiter_default_resources_per_bucket: 5
# rollup_rate_limiter_default_refill_rate: 5

# Custom limits per address (resources in 1/1000th of batch capacity)
# rollup_rate_limiter_address_limits:
#   - address: "0xA6edfca3AA985Dd3CC728BFFB700933a986aC085"
#     resources_per_bucket: 20
#     refill_rate: 2

# Custom limits per IP
# rollup_rate_limiter_ip_limits:
#   - ip: "127.0.0.1"
#     resources_per_bucket: 1000
#     refill_rate: 1

# ============================================
# Leader Election (Preferred Sequencer + Postgres Only)
# ============================================
# Maps to [sequencer.preferred.postgres_config.leader_election]. Only applies
# when rollup_sequencer_postgres_connection_string is set. Values shown are the
# role defaults.

# Max time (ms) without a heartbeat before a leader is considered inactive
# rollup_leader_election_leader_timeout_millis: 1000
# Min time (ms) after leader acquisition before another node can take over
# rollup_leader_election_grace_period_millis: 10000
# Interval (ms) between heartbeat updates
# rollup_leader_election_heartbeat_interval_millis: 100

# ============================================
# Price Oracle (optional)
# ============================================
# When enabled, the rollup connects to the configured oracle source(s) for price
# feeds and is started with --oracle-config-path. NOTE: the deployed rollup must
# support the price oracle -- enabling this against a binary that predates oracle
# support makes it reject the unknown argument and fail to start. When disabled
# the flag is left commented-out in rollup-manager.sh for manual debugging.

# oracle_enabled: false
# Block startup until all sources connect (only applies when oracle_enabled).
# oracle_require_sources: false
# At least one source is required when oracle_enabled is true.
# oracle_sources:
#   - name: "chainlink-1"
#     provider: "chainlink"
#     address: "127.0.0.1:9801"
#   - name: "stork-1"
#     provider: "stork"
#     address: "127.0.0.1:9804"

# ============================================
# Data Availability - Mock DA
# ============================================

# da_start_height: 1
# da_rollup_address: "0xA6edfca3AA985Dd3CC728BFFB700933a986aC085"

# ============================================
# Data Availability - Celestia
# ============================================

# DA start height (set to recent height to reduce sync time)
# da_start_height: 1

# Rollup address for DA submissions. Should match signer key in `vars/celestia_secrets.yaml`
# da_rollup_address: "celestia1jk6xx55wum73al8f2mp54x92uggqws8ksnjus2"

# Batch and proof namespaces (must be exactly 10 characters)
# rollup_batch_namespace: "sov-batch1"
# rollup_proof_namespace: "sov-proof1"

# Note: Celestia RPC/gRPC URLs and secrets go in vars/celestia_secrets.yaml

# ============================================
# Constants.toml Overrides
# ============================================
# These values override the defaults in the rollup's constants.toml file
# Only specify values you want to change - unset variables use rollup defaults

# rollup_chain_id: 6669
# rollup_chain_name: "MyChain"
# rollup_hyperlane_bridge_domain: 5555
# rollup_deferred_slots_count: 100000
# rollup_hyperlane_meter_delivery_counter_after_height: 0
# rollup_chain_hash_overrides:
#   - start_height: 0
#     end_height: 1000
#     chain_hash: "0xabc...32_bytes_hex"
#     grace_period: 100

# ============================================
# zkVM - Risc0
# ============================================

# risc0_cargo_version: "1.2.0"
# risc0_toolchain_version: "r0.1.81.0"

# ============================================
# zkVM - SP1
# ============================================

# sp1_version: "6.0.2"
# sp1_github_token: ""

# ============================================
# Example: Full override for production
# ============================================

# debug: false
# rollup_commit_hash: "abc123def456"
# zkvm_role: "risc0"
# max_open_files: 2000000
# da_start_height: 6739020
