{
  "versions": [
{% for version in version_spec.rollup_versions %}
{% set migration_crate = version.rollup_db_migration_crate | default(rollup_db_migration_crate) %}
{% set migration_binary = versions_output_dir ~ '/' ~ version.version_id ~ '/' ~ migration_crate %}
    {
      "rollup_binary": "{{ versions_output_dir }}/{{ version.version_id }}/rollup",
      "config_path": "{{ versions_output_dir }}/{{ version.version_id }}/rollup_config.toml",
      "migration_path": {{ (migration_binary if (version.build_db_migration | default(false) | bool) else (version.migration_path | default(none, true))) | to_json }},
      "start_height": {{ version.start_height | default('null') | to_json }},
      "stop_height": {{ version.stop_height | default('null') | to_json }}
    }{% if not loop.last %},{% endif %}

{% endfor %}
  ]
}
