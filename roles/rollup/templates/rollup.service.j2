[Unit]
Description=Rollup
After=network.target
StartLimitIntervalSec=0

[Service]
Type=simple
ExecStart=/home/sovereign/rollup-manager.sh
Restart=always
RestartSec=3
User=sovereign
LimitNOFILE={{ max_open_files }}
# Drop-valve: bound journald's per-unit log rate so a storm sheds messages instead
# of back-pressuring (blocking) the rollup's stdout writes and stalling the node.
# Do NOT set the interval to 0 — that disables the valve and reintroduces the stall.
LogRateLimitIntervalSec=30s
LogRateLimitBurst=20000
StandardOutput=journal
StandardError=journal
Environment="PATH=/home/sovereign/.cargo/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/usr/games:/snap/bin:/home/sovereign/.local/bin/"

{% if opentelemetry_available | default(false) | bool %}
{% if opentelemetry_mode == "logs" %}
Environment=OTEL_EXPORTER_OTLP_LOGS_ENDPOINT="http://127.0.0.1:4317"
{% elif opentelemetry_mode == "full" %}
Environment=SOV_OTEL_ENABLED=1
{% endif %}
{% endif %}

[Install]
WantedBy=multi-user.target
