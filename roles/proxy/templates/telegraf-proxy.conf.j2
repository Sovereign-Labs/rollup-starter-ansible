# Proxy (OpenResty/nginx) Telegraf inputs

{% if proxy_vts_enabled | bool %}
# Per-vhost / per-upstream / per-status-code metrics from ngx_http_vhost_traffic_status_module.
# Endpoint is localhost-only (see openresty-{http,https}.conf.j2).
[[inputs.nginx_vts]]
  urls = ["http://127.0.0.1:{{ proxy_vts_status_port }}/vts_status/format/json"]
  response_timeout = "5s"
  [inputs.nginx_vts.tags]
    source = "openresty-proxy"
{% else %}
# stub_status fallback (active/reading/writing/waiting/accepts/handled/requests).
# Enable proxy_vts_enabled for richer per-vhost/per-upstream/per-status metrics.
[[inputs.nginx]]
  urls = ["http://127.0.0.1:{{ proxy_listen_port }}/nginx_status"]
  response_timeout = "5s"
  [inputs.nginx.tags]
    source = "openresty-proxy"
{% endif %}
