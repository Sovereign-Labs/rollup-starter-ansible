# Managed by Ansible (roles/proxy). Readable only by root (mode 0600).
# Only the DB password lives here. It is kept out of the systemd unit's
# ExecStart because that unit file is world-readable (0644); this file is
# 0600, so the secret is not exposed on disk to non-root users. Non-secret
# flags such as --output-file are inlined directly in the unit instead.
DATABASE_URL={{ rollup_sequencer_postgres_connection_string }}
