{% if proxy_geoip_enabled | bool %}
# GeoIP2 country lookup. Reads the mmdb seeded by tasks/geoip.yaml and refreshed
# daily by /usr/local/share/proxy/geoip-refresh.yml (an Ansible playbook
# invoked from /etc/cron.d/update-geoip-dbs via `ansible-playbook -c local`);
# auto_reload picks up new files within 5 minutes without an openresty reload.
geoip2 {{ proxy_geoip_mmdb_path }} {
    auto_reload 5m;
    $geoip2_data_country_iso_code country iso_code;
}

# Countries to block (ISO 3166-1 alpha-2). Empty list = block nothing.
map $geoip2_data_country_iso_code $geoip_country_blocked {
    default 0;
{% for c in proxy_geoip_blocked_countries %}
    "{{ c }}" 1;
{% endfor %}
}
{% else %}
# GeoIP disabled — stub so http-base.conf's `include conf.d/geoip-setup.conf;`
# stays valid and conf.d/geoip-block.conf (when included anywhere) is a no-op.
map $uri $geoip_country_blocked {
    default 0;
}
{% endif %}
