# HTTP base config included in the http {} block.

{% if proxy_geoip_enabled | bool %}
geoip2 {{ proxy_geoip_mmdb_path }} {
    auto_reload 5m;
    $geoip2_data_country_iso_code country iso_code;
}
map $geoip2_data_country_iso_code $geoip_country_blocked {
    default 0;
{% for c in proxy_geoip_blocked_countries %}
    "{{ c }}" 1;
{% endfor %}
}
{% endif %}

{% if proxy_vts_enabled | bool %}
vhost_traffic_status_zone;
{% endif %}

{% if proxy_cloudflare_real_ip | bool %}
# Trust CF-Connecting-IP only from Cloudflare edge CIDRs (see vars/main.yaml).
real_ip_header CF-Connecting-IP;
real_ip_recursive on;
{% for cidr in proxy_cloudflare_cidrs_v4 + proxy_cloudflare_cidrs_v6 %}
set_real_ip_from {{ cidr }};
{% endfor %}

{% endif %}
include /usr/local/openresty/nginx/conf/mime.types;
default_type application/json;

# Redact API keys in /rpc/<key> from access logs.
map $request_uri $logged_request_uri {
    ~^/rpc/[A-Za-z0-9_-]+(?:(/)?(\?.*)?)$ /rpc/[redacted]$1$2;
    default $request_uri;
}

log_format main '$remote_addr - $remote_user [$time_local] "$request_method $logged_request_uri $server_protocol" '
                '$status $body_bytes_sent "$http_referer" '
                '"$http_user_agent" "$http_x_forwarded_for" '
                'rt=$request_time backend=$upstream_addr';

access_log /var/log/nginx/access.log main;

sendfile           on;
tcp_nopush         on;
tcp_nodelay        on;
keepalive_timeout  65;
keepalive_requests 1000;

client_body_buffer_size    128k;
client_max_body_size       1m;
client_header_buffer_size  1k;
large_client_header_buffers 4 4k;

gzip on;
gzip_vary on;
gzip_min_length 1024;
gzip_types application/json application/javascript application/xml application/xml+rss text/css text/javascript text/plain text/xml;

proxy_buffering        on;
proxy_buffer_size      64k;
proxy_buffers          8 64k;
proxy_busy_buffers_size 128k;
proxy_http_version     1.1;

{% if proxy_dns_resolver | length > 0 %}
resolver {{ proxy_dns_resolver }} valid=10s;
{% endif %}

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

lua_shared_dict backend_cache 1m;
{% if proxy_unlimited_domains | length > 0 %}
lua_shared_dict failed_auth_limit 10m;
{% endif %}
lua_package_path "/usr/local/openresty/nginx/conf/conf.d/?.lua;;";

{% if proxy_node_discovery_enabled | bool %}
init_by_lua_file {{ proxy_node_discovery_output_file }};
{% else %}
init_worker_by_lua_block {
    local cache = ngx.shared.backend_cache
    cache:set("leader", "{{ proxy_rollup_leader_ip }}:{{ rollup_http_port }}")
    cache:set("follower_1", "{{ proxy_rollup_follower_ip | default(proxy_rollup_leader_ip, true) }}:{{ rollup_http_port }}")
}
{% endif %}

{% if proxy_unlimited_domains | length > 0 %}
# $uri is rewritten before the access phase, so match against $request_uri.
map $request_uri $valid_api_key {
{% for key in proxy_api_keys %}
    ~^/rpc/{{ key }}(/|\?|$) 1;
{% endfor %}
    default 0;
}
{% endif %}

{% if proxy_rate_limit_enabled | bool %}
geo $ip_exempt {
    default 0;
{% for ip in proxy_rate_limit_exempt_ips %}
    {{ ip }} 1;
{% endfor %}
}

# proxy_unlimited_domains hosts are rate-exempt by Host (API key still required
# in secure-rpc-locations.conf); failed-auth attempts remain per-IP throttled.
map $host $host_exempt {
    default 0;
{% for domain in proxy_unlimited_domains %}
    "{{ domain }}" 1;
{% endfor %}
}

map "$ip_exempt:$host_exempt" $rate_limit_key {
    "0:0"   $binary_remote_addr;
    default "";
}

limit_req_zone $rate_limit_key zone=global_limit:10m rate={{ proxy_rate_limit_rate }};
{% endif %}
