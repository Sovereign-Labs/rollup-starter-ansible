# Main proxy location with dynamic backend selection
# Included in server {} blocks

location / {
{% if proxy_rate_limit_enabled %}
    # Apply conditional rate limiting
    limit_req zone=global_limit burst={{ proxy_rate_limit_burst }} nodelay;
    limit_req_status 429;
{% endif %}

    # Bare `/` is the JSON-RPC endpoint for standard ETH clients; route it
    # exactly like /rpc so the eth_sendRawTransaction* leader check applies.
    rewrite ^/$ /rpc break;

    set $backend '';

    access_by_lua_block {
        require("backend-select").select(ngx.var.uri)
    }

    proxy_pass http://$backend;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # WebSocket support
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;

    # Timeouts
    proxy_connect_timeout {{ proxy_connect_timeout }};
    proxy_send_timeout {{ proxy_websocket_timeout }};
    proxy_read_timeout {{ proxy_websocket_timeout }};
}
