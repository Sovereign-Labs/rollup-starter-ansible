# Shared proxy_pass headers + timeouts for upstream rollup nodes.
# Included from conf.d/proxy-location.conf and conf.d/secure-rpc-locations.conf.

proxy_set_header Host $host;
proxy_set_header X-Real-IP $remote_addr;
proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
proxy_set_header X-Forwarded-Proto $scheme;

# WebSocket support
proxy_set_header Upgrade $http_upgrade;
proxy_set_header Connection $connection_upgrade;

# Timeouts
proxy_connect_timeout {{ proxy_connect_timeout }};
proxy_send_timeout {{ proxy_websocket_timeout }};
proxy_read_timeout {{ proxy_websocket_timeout }};
