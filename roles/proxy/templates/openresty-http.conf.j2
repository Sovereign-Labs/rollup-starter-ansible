{%- set _public_domains = ([proxy_domain_name] + proxy_unlimited_domains) if (proxy_domain_name | length > 0) else ['_'] %}
worker_processes auto;
error_log /var/log/nginx/error.log warn;
pid /usr/local/openresty/nginx/logs/nginx.pid;

{% if proxy_geoip_enabled | bool %}
load_module modules/ngx_http_geoip2_module.so;
{% endif %}
{% if proxy_vts_enabled | bool %}
load_module modules/ngx_http_vhost_traffic_status_module.so;
{% endif %}

events {
    worker_connections 4096;
    use epoll;
    multi_accept on;
}

http {
    include conf.d/http-base.conf;

{% if proxy_vts_enabled | bool %}
    # VTS metrics endpoint — scraped by Telegraf's inputs.nginx_vts.
    # Localhost-only listener so it's not externally reachable.
    server {
        listen 127.0.0.1:{{ proxy_vts_status_port }};

        location /vts_status {
            vhost_traffic_status_display;
            vhost_traffic_status_display_format json;
            access_log off;
        }
    }

{% endif %}
    server {
        listen {{ proxy_listen_port }};
        server_name {{ _public_domains | join(' ') }};

        location /health {
            access_log off;
            default_type text/plain;
            return 200 "healthy\n";
        }

        location /nginx_status {
            stub_status on;
            access_log off;
            allow 127.0.0.1;
            deny all;
        }

        location /.well-known/acme-challenge/ {
            root {{ proxy_certbot_webroot }};
        }

        include conf.d/proxy-location.conf;
    }

{% if proxy_api_key_auth_enabled | bool %}
    # Secure server: API-key-protected /rpc/<key> for proxy_secure_domain_names.
    server {
        listen {{ proxy_listen_port }};
        server_name {{ proxy_secure_domain_names | join(' ') }};

        location /health {
            access_log off;
            default_type text/plain;
            return 200 "healthy\n";
        }

        location /.well-known/acme-challenge/ {
            root {{ proxy_certbot_webroot }};
        }

        include conf.d/secure-rpc-locations.conf;
    }
{% endif %}
}
