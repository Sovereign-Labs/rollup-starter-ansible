{%- set _public_domains = proxy_public_domains + proxy_unlimited_domains %}
{%- set _http_redirect_domains = _public_domains + (proxy_secure_domains if proxy_api_key_auth_enabled | bool else []) %}
worker_processes auto;
error_log /var/log/nginx/error.log warn;
pid /usr/local/openresty/nginx/logs/nginx.pid;

{% if proxy_geoip_enabled | bool %}
load_module modules/ngx_http_geoip2_module.so;
{% endif %}
{% if proxy_vts_enabled | bool %}
load_module modules/ngx_http_vhost_traffic_status_module.so;
{% endif %}

events {
    worker_connections 4096;
    use epoll;
    multi_accept on;
}

http {
    include conf.d/http-base.conf;

{% if proxy_vts_enabled | bool %}
    # VTS metrics endpoint — scraped by Telegraf's inputs.nginx_vts.
    # Localhost-only listener so it's not externally reachable.
    server {
        listen 127.0.0.1:{{ proxy_vts_status_port }};

        location /vts_status {
            vhost_traffic_status_display;
            vhost_traffic_status_display_format json;
            access_log off;
        }
    }

{% endif %}
    # HTTP server - redirect to HTTPS and handle ACME challenges
    server {
        listen {{ proxy_listen_port }};
        server_name {{ _http_redirect_domains | join(' ') }};

        location /health {
            access_log off;
            default_type text/plain;
            return 200 "healthy\n";
        }

        location /nginx_status {
            stub_status on;
            access_log off;
            allow 127.0.0.1;
            deny all;
        }

        location /.well-known/acme-challenge/ {
            root {{ proxy_certbot_webroot }};
        }

        # Redirect all other HTTP traffic to HTTPS
        location / {
            return 301 https://$host{% if proxy_listen_port_ssl | int != 443 %}:{{ proxy_listen_port_ssl }}{% endif %}$request_uri;
        }
    }

    # HTTPS server - main public proxy
    server {
        listen {{ proxy_listen_port_ssl }} ssl;
        http2 on;
        server_name {{ _public_domains | join(' ') }};

        include conf.d/ssl.conf;
        include conf.d/security-headers.conf;

        location /health {
            access_log off;
            default_type text/plain;
            return 200 "healthy\n";
        }

        include conf.d/proxy-location.conf;
    }

{% if proxy_api_key_auth_enabled | bool %}
    # HTTPS server - API-key-protected /rpc/<key> for proxy_secure_domains.
    server {
        listen {{ proxy_listen_port_ssl }} ssl;
        http2 on;
        server_name {{ proxy_secure_domains | join(' ') }};

        include conf.d/ssl.conf;
        include conf.d/security-headers.conf;

        location /health {
            access_log off;
            default_type text/plain;
            return 200 "healthy\n";
        }

        include conf.d/secure-rpc-locations.conf;
    }
{% endif %}
}
